FLOWITH_API_KEY=flo-your-key
FLOWITH_BASE_URL=https://edge.flowith.io/external/use/llm
FLOWITH_DEFAULT_MODEL=claude-5-sonnet

FLOWITH_TIMEOUT=300
FLOWITH_CONNECT_TIMEOUT=30
FLOWITH_MAX_CONCURRENCY=8
FLOWITH_SEMAPHORE_TIMEOUT=30
FLOWITH_POOL_MAXSIZE=16
FLOWITH_RETRY_TOTAL=6
FLOWITH_RETRY_BACKOFF=0.5
FLOWITH_RETRY_JITTER=0.25
FLOWITH_RETRY_MAX_DELAY=8
FLOWITH_SSL_RETRY_EXTRA=10
# Empty-response retry budget. Keep it bounded: oversized Fable contexts return
# empty deterministically, so long/unlimited retries only make the client hang.
FLOWITH_EMPTY_RETRY_WINDOW=8
FLOWITH_EMPTY_RETRY_TOTAL=8
FLOWITH_EMPTY_RETRY_DELAY=0.35
FLOWITH_EMPTY_RETRY_DELAY_MAX=1
# One recovery attempt after an empty long-context request. Keeps the system
# prompt and newest messages under this budget; set 0 to disable.
FLOWITH_EMPTY_CONTEXT_FALLBACK_CHARS=90000
# Preemptively trim only Fable history before its known empty-response wall.
FLOWITH_FABLE_CONTEXT_COMPACT_CHARS=90000
# Use this non-Fable model after a compacted/retried Fable request is still empty.
# Set blank to disable the transparent model fallback.
FLOWITH_FABLE_FALLBACK_MODEL=claude-5-sonnet
# Abort a non-Fable stream that emits no model delta for this many seconds.
FLOWITH_STREAM_IDLE_TIMEOUT=150
# Abort a Fable stream with no first delta after this many seconds and retry it.
FLOWITH_FABLE_STREAM_IDLE_TIMEOUT=45
# Emit a real Responses SSE event while waiting so Codex does not expire its
# event-level idle timer. Comments alone (": ping") are not sufficient.
FLOWITH_SSE_HEARTBEAT_INTERVAL=5
FLOWITH_DISABLE_KEEPALIVE=true
FLOWITH_SSL_VERIFY=true
FLOWITH_UPSTREAM_PROXY=

FLOWITH_API_HOST=127.0.0.1
FLOWITH_API_PORT=8787
FLOWITH_API_PROFILE=all
FLOWITH_LOCAL_ONLY=true
FLOWITH_REQUIRE_SERVER_KEY=false
FLOWITH_OPEN_DASHBOARD=true

FLOWITH_TOOL_MODE=xml
FLOWITH_RESPONSES_COMPACT_FINAL_TEXT=false
# Consolidate semantically repeated Hermes draft/interim/final prose. The
# dedicated 8789 launcher enables this without changing normal Codex 8788.
FLOWITH_HERMES_SINGLE_ANSWER=false
FLOWITH_MODEL_ALIASES={"claude-5-sonnet":"claude-5-sonnet","claude-opus-4.7":"claude-opus-4.7","claude-opus-4.8":"claude-opus-4.8","claude-haiku-4-5":"claude-haiku-4-5","claude-fable-5":"claude-fable-5","gpt-5.5":"gpt-5.5","gpt-5.4":"gpt-5.4","gpt-5.4-flowith-5.6":"gpt-5.6-sol","gpt-4.1":"gpt-4.1","gemini-2.5-pro":"gemini-2.5-pro","deepseek-chat":"deepseek-chat","gpt-5.6-sol":"gpt-5.6-sol","gpt-5.6-terra":"gpt-5.6-terra","gpt-5.6-luna":"gpt-5.6-luna"}

FLOWITH_DEBUG_DUMP=false
FLOWITH_DEBUG_DUMP_DIR=
FLOWITH_TRACE_HERMES=false
FLOWITH_REQUEST_LOG=false
FLOWITH_MAX_REQUEST_BYTES=20971520
FLOWITH_DEBUG_DUMP_MAX_BYTES=1048576
FLOWITH_DEBUG_DUMP_MAX_FILES=100
