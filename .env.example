# ===== Required =====
# Flowith API key — get one from https://edge.flowith.io (format: fw_xxx or flo_xxx)
FLOWITH_API_KEY=

# ===== Network / Proxy (important for users in China) =====
# Direct connections to edge.flowith.io may be disrupted by DPI/firewalls.
# Route upstream requests through a local proxy (Clash, V2Ray, Sing-box, etc.).
# Falls back to HTTPS_PROXY / HTTP_PROXY env vars if not set here.
FLOWITH_UPSTREAM_PROXY=http://127.0.0.1:7890
# For SOCKS5 proxies:
# FLOWITH_UPSTREAM_PROXY=socks5://127.0.0.1:7891

# Disable upstream TLS verification — only use as a last resort when your
# proxy/VPN/firewall breaks TLS handshakes even with the proxy configured.
FLOWITH_SSL_VERIFY=false

# ===== Optional (defaults are fine for most users) =====
# FLOWITH_BASE_URL=https://edge.flowith.io/external/use/llm
# FLOWITH_DEFAULT_MODEL=claude-4.6-sonnet
# FLOWITH_API_HOST=127.0.0.1
# FLOWITH_API_PORT=8787
# FLOWITH_TIMEOUT=120

# ===== Custom model mapping (optional) =====
# JSON string mapping Claude model names to Flowith model ids.
# Merges with built-in aliases; user aliases take priority.
# FLOWITH_MODEL_ALIASES={"claude-3-5-sonnet-20241022":"claude-4.6-sonnet"}
